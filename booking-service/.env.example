APP_NAME="Retobluto Booking Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8004

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Docker:
# DB_HOST=booking-db
# DB_DATABASE=booking_db
# DB_USERNAME=booking_user
# DB_PASSWORD=booking_password
#
# Local XAMPP:
# DB_HOST=127.0.0.1
# DB_DATABASE=arenalo_booking_db
# DB_USERNAME=root
# DB_PASSWORD=
DB_CONNECTION=mysql
DB_HOST=booking-db
DB_PORT=3306
DB_DATABASE=booking_db
DB_USERNAME=booking_user
DB_PASSWORD=booking_password

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
CACHE_PREFIX=booking_service_cache

QUEUE_CONNECTION=redis

# Docker: REDIS_HOST=redis
# Local:  REDIS_HOST=127.0.0.1
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=

MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@retobluto.test"
MAIL_FROM_NAME="Retobluto Arena"

# Docker:
# AUTH_SERVICE_URL=http://auth-service:8000
# MEMBER_SERVICE_URL=http://member-service:8000
# FIELD_SERVICE_URL=http://field-service:8000
# NOTIFICATION_SERVICE_URL=http://notification-service:8000
#
# Local:
# AUTH_SERVICE_URL=http://127.0.0.1:8001
# MEMBER_SERVICE_URL=http://127.0.0.1:8002
# FIELD_SERVICE_URL=http://127.0.0.1:8003
# NOTIFICATION_SERVICE_URL=http://127.0.0.1:8005
AUTH_SERVICE_URL=http://auth-service:8000
MEMBER_SERVICE_URL=http://member-service:8000
FIELD_SERVICE_URL=http://field-service:8000
NOTIFICATION_SERVICE_URL=http://notification-service:8000

INTERNAL_SERVICE_SECRET=retobluto_internal_secret

HASURA_REPORTING_ENABLED=true

# Docker:
# HASURA_DATABASE_HOST=hasura-db
# HASURA_DATABASE_PORT=5432
#
# Local:
# HASURA_DATABASE_HOST=127.0.0.1
# HASURA_DATABASE_PORT=5433
HASURA_DATABASE_HOST=hasura-db
HASURA_DATABASE_PORT=5432
HASURA_DATABASE_NAME=hasura_db
HASURA_DATABASE_USERNAME=hasura_user
HASURA_DATABASE_PASSWORD=hasura_password