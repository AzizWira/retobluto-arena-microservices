APP_NAME="Retobluto Arena Microservices"
APP_ENV=local

# Network
DOCKER_NETWORK=retobluto_network

# Auth Service
AUTH_SERVICE_PORT=8001
AUTH_DB_HOST=auth-db
AUTH_DB_PORT=3306
AUTH_DB_DATABASE=auth_db
AUTH_DB_USERNAME=auth_user
AUTH_DB_PASSWORD=auth_password
AUTH_DB_ROOT_PASSWORD=root

# Member Service
MEMBER_SERVICE_PORT=8002
MEMBER_DB_HOST=member-db
MEMBER_DB_PORT=3306
MEMBER_DB_DATABASE=member_db
MEMBER_DB_USERNAME=member_user
MEMBER_DB_PASSWORD=member_password
MEMBER_DB_ROOT_PASSWORD=root

# Field Service
FIELD_SERVICE_PORT=8003
FIELD_DB_HOST=field-db
FIELD_DB_PORT=3306
FIELD_DB_DATABASE=field_db
FIELD_DB_USERNAME=field_user
FIELD_DB_PASSWORD=field_password
FIELD_DB_ROOT_PASSWORD=root

# Booking Service
BOOKING_SERVICE_PORT=8004
BOOKING_DB_HOST=booking-db
BOOKING_DB_PORT=3306
BOOKING_DB_DATABASE=booking_db
BOOKING_DB_USERNAME=booking_user
BOOKING_DB_PASSWORD=booking_password
BOOKING_DB_ROOT_PASSWORD=root

# Notification Service
NOTIFICATION_SERVICE_PORT=8005
NOTIFICATION_DB_HOST=notification-db
NOTIFICATION_DB_PORT=3306
NOTIFICATION_DB_DATABASE=notification_db
NOTIFICATION_DB_USERNAME=notification_user
NOTIFICATION_DB_PASSWORD=notification_password
NOTIFICATION_DB_ROOT_PASSWORD=root

# GraphQL Gateway
GRAPHQL_GATEWAY_PORT=8010

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# Hasura
HASURA_PORT=8080
HASURA_GRAPHQL_ADMIN_SECRET=retobluto_admin_secret
HASURA_POSTGRES_HOST=hasura-db
HASURA_POSTGRES_PORT=5432
HASURA_POSTGRES_DB=hasura_db
HASURA_POSTGRES_USER=hasura_user
HASURA_POSTGRES_PASSWORD=hasura_password

# Mail Default
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@retobluto.test
MAIL_FROM_NAME="Retobluto Arena"