APP_NAME="Retobluto Field Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8003

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Docker:
# DB_HOST=field-db
# DB_DATABASE=field_db
# DB_USERNAME=field_user
# DB_PASSWORD=field_password
#
# Local XAMPP:
# DB_HOST=127.0.0.1
# DB_DATABASE=arenalo_field_db
# DB_USERNAME=root
# DB_PASSWORD=
DB_CONNECTION=mysql
DB_HOST=field-db
DB_PORT=3306
DB_DATABASE=field_db
DB_USERNAME=field_user
DB_PASSWORD=field_password

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
CACHE_PREFIX=field_service_cache

QUEUE_CONNECTION=redis

# Docker: REDIS_HOST=redis
# Local:  REDIS_HOST=127.0.0.1
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=

MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@retobluto.test"
MAIL_FROM_NAME="Retobluto Arena"

# Docker:
# AUTH_SERVICE_URL=http://auth-service:8000
# BOOKING_SERVICE_URL=http://booking-service:8000
#
# Local:
# AUTH_SERVICE_URL=http://127.0.0.1:8001
# BOOKING_SERVICE_URL=http://127.0.0.1:8004
AUTH_SERVICE_URL=http://auth-service:8000
BOOKING_SERVICE_URL=http://booking-service:8000