APP_NAME="Retobluto Auth Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8001

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =========================
# DATABASE
# Docker:
# DB_HOST=auth-db
# DB_DATABASE=auth_db
# DB_USERNAME=auth_user
# DB_PASSWORD=auth_password
#
# Local XAMPP:
# DB_HOST=127.0.0.1
# DB_DATABASE=arenalo_auth_db
# DB_USERNAME=root
# DB_PASSWORD=
# =========================
DB_CONNECTION=mysql
DB_HOST=auth-db
DB_PORT=3306
DB_DATABASE=auth_db
DB_USERNAME=auth_user
DB_PASSWORD=auth_password

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
CACHE_PREFIX=auth_service_cache

QUEUE_CONNECTION=redis

# Docker:
# REDIS_HOST=redis
#
# Local:
# REDIS_HOST=127.0.0.1
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=

MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@retobluto.test"
MAIL_FROM_NAME="Retobluto Arena"

BCRYPT_ROUNDS=12

JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160
JWT_ALGO=HS256

# Docker:
# MEMBER_SERVICE_URL=http://member-service:8000
# NOTIFICATION_SERVICE_URL=http://notification-service:8000
#
# Local:
# MEMBER_SERVICE_URL=http://127.0.0.1:8002
# NOTIFICATION_SERVICE_URL=http://127.0.0.1:8005
MEMBER_SERVICE_URL=http://member-service:8000
NOTIFICATION_SERVICE_URL=http://notification-service:8000

INTERNAL_SERVICE_SECRET=retobluto_internal_secret