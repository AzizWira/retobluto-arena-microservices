APP_NAME="Retobluto GraphQL Gateway"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8010

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=/tmp/graphql_gateway.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
QUEUE_CONNECTION=sync

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@retobluto.test"
MAIL_FROM_NAME="Retobluto GraphQL Gateway"

AUTH_SERVICE_URL=http://auth-service:8000
MEMBER_SERVICE_URL=http://member-service:8000
FIELD_SERVICE_URL=http://field-service:8000
BOOKING_SERVICE_URL=http://booking-service:8000
NOTIFICATION_SERVICE_URL=http://notification-service:8000

GATEWAY_TIMEOUT=8

VITE_APP_NAME="${APP_NAME}"